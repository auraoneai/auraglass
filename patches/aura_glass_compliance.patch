diff --git a/src/components/input/GlassInput.tsx b/src/components/input/GlassInput.tsx
index abc3456..def7890 100644
--- a/src/components/input/GlassInput.tsx
+++ b/src/components/input/GlassInput.tsx
@@ -1,16 +1,32 @@
 import React from 'react';
+import { ContrastGuard } from '@/lib/contrastGuard';

 interface GlassInputProps extends React.InputHTMLAttributes<HTMLInputElement> {
   label?: string;
+  error?: string;
 }

 export function GlassInput({
   label,
+  error,
   className = '',
+  id,
+  'aria-label': ariaLabel,
   ...props
 }: GlassInputProps) {
+  // FIX: Generate ID if not provided
+  const inputId = id || `glass-input-${React.useId()}`;
+
+  // FIX: Require either label or aria-label
+  const accessibleLabel = label || ariaLabel;
+  if (!accessibleLabel && process.env.NODE_ENV === 'development') {
+    console.warn('GlassInput: Either "label" or "aria-label" prop is required for accessibility');
+  }
+
   return (
     <div className="glass-input-wrapper">
-      {label && <label>{label}</label>}
+      {/* FIX: Associate label with input using htmlFor */}
+      {label && (
+        <label htmlFor={inputId} className="glass-label">
+          <ContrastGuard minRatio={4.5}>
+            {label}
+          </ContrastGuard>
+        </label>
+      )}
       <input
+        id={inputId}
+        aria-label={!label ? ariaLabel : undefined}
+        aria-describedby={error ? `${inputId}-error` : undefined}
+        aria-invalid={error ? 'true' : 'false'}
         className={`glass-input ${className}`}
         style={{
-          background: 'rgba(255, 255, 255, 0.08)',
-          backdropFilter: 'blur(8px)',
+          // FIX: Use design tokens
+          background: 'rgba(var(--glass-color-white) / var(--glass-opacity-10))',
+          backdropFilter: 'var(--glass-backdrop-blur)',
+          border: '1px solid var(--glass-border-default)',
+          borderRadius: 'var(--glass-radius-md)',
           padding: '12px 16px',
-          borderRadius: '8px',
+          color: 'var(--glass-text-primary)',
+          transition: 'var(--glass-transition)',
         }}
         {...props}
       />
+      {/* FIX: Add error message with aria-live for announcements */}
+      {error && (
+        <div
+          id={`${inputId}-error`}
+          role="alert"
+          aria-live="polite"
+          className="glass-input-error"
+        >
+          <ContrastGuard minRatio={4.5}>
+            {error}
+          </ContrastGuard>
+        </div>
+      )}
     </div>
   );
 }

