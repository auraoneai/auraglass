              />
            </svg>
          </button>
        </div>
        <button
          aria-label="Open floating actions menu"
          class="glass-w-14 glass-h-14 glass-radius-full glass-surface-dark glass-text-primary glass-flex glass-items-center glass-justify-center glass-shadow-lg glass-hover-bg-slate-600 glass-mt-2"
          style="border: 1px solid rgba(255,255,255,0.5); border-radius: 12px; box-shadow: 0px 8px 24px 0px rgba(0,0,0,0.2); transition: all 200ms ease-out; position: relative; transform: translateZ(0);"
        >
          ⚡
        </button>
      </div>
    </div>
  </div>
</div>
