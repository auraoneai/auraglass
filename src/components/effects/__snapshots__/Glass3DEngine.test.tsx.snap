  <div
    class="glass-3d-content"
    style="position: relative; z-index: 6; transform: translateZ(100px);"
  />
  <div
    class="glass-parallax-background"
    data-glass-overlay="true"
    style="position: absolute; inset: -20%; transform: none;"
  />
  <style>
    
        .glass-3d-container {
          --glass-3d-perspective: 1000px;
        }

        .interaction-pulse {
          animation: pulse-3d 1s ease-out infinite;
        }

        @keyframes pulse-3d {
          0% {
            transform: translate(-50%, -50%) scale(1) translateZ(0);
            opacity: 1;
          }
          100% {
            transform: translate(-50%, -50%) scale(3) translateZ(20px);
            opacity: 0;
          }
        }
      
  </style>
