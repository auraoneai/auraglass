    "rollup-plugin-typescript2": "^0.36.0",
    "rollup-preserve-directives": "^1.1.3",
    "storybook": "9.1.20",
    "three": "^0.170.0",
    "ts-jest": "^29.4.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.1.0",
    "vite": "^7.1.5"
  },
  "dependencies": {
    "chart.js": "^4.5.0",
    "clsx": "^2.0.0",
    "date-fns": "^4.1.0",
    "socket.io-client": "^4.8.3",
    "tailwind-merge": "^3.3.1",
    "zod": "^3.22.0"
  },
  "overrides": {
    "@tootallnate/once": "^3.0.1",
    "github-build": {
      "axios": "^1.16.0"
    },
    "scheduler": "^0.23.0",
    "serialize-javascript": "^7.0.5"
  },
  "bundlesize": [
    {
      "path": "./dist/index.mjs",
      "maxSize": "950 kB",
      "compression": "gzip"
    },
    {
      "path": "./dist/styles/index.css",
      "maxSize": "35 kB",
      "compression": "gzip"
    },
    {
      "path": "./dist/three/index.mjs",
      "maxSize": "35 kB",
      "compression": "gzip"
    },
    {
      "path": "./dist/tokens/index.mjs",
      "maxSize": "1 kB",
      "compression": "gzip"
    }
  ],
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "sideEffects": [
    "*.css",
    "src/styles/**/*"
  ],
  "lint-staged": {
    "src/**/!(*.stories).{ts,tsx}": [
      "eslint --fix --max-warnings 999999",
      "prettier --write"
    ],
    "src/**/*.{css,scss}": [
      "prettier --write",
      "node scripts/ci/token-lint.js"
    ],
    "src/**/*.{json,md}": [
      "prettier --write"
    ]
  },
  "engines": {
    "node": ">=18.18.0",
    "npm": ">=9.0.0"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
