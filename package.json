{
  "name": "aura-glass",
  "version": "3.0.4",
  "description": "React Liquid Glass and glassmorphism component library with 356 certified UI components, Next.js/SSR support, TypeScript, accessibility, tokens, Storybook, and 3D/AR.",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./tokens": {
      "types": "./dist/tokens/generated.d.ts",
      "import": "./dist/tokens/index.mjs",
      "require": "./dist/tokens/index.cjs",
      "default": "./dist/tokens/index.mjs"
    },
    "./tokens/json": {
      "import": "./dist/tokens/tokens.json",
      "default": "./dist/tokens/tokens.json"
    },
    "./tokens/tailwind": {
      "import": "./dist/tokens/tailwind.theme.mjs",
      "require": "./dist/tokens/tailwind.theme.cjs",
      "default": "./dist/tokens/tailwind.theme.mjs"
    },
    "./tokens/manifest": {
      "import": "./dist/tokens/manifest.mjs",
      "default": "./dist/tokens/manifest.mjs"
    },
    "./tokens/css": "./dist/tokens/tokens.css",
    "./tokens/keyframes": "./dist/tokens/tokens.keyframes.css",
    "./styles": "./dist/styles/index.css",
    "./core/mixins/glassMixins": {
      "types": "./dist/core/mixins/glassMixins.d.ts",
      "import": "./dist/esm/core/mixins/glassMixins.js",
      "default": "./dist/esm/core/mixins/glassMixins.js"
    },
    "./utils/env": {
      "types": "./dist/utils/env.d.ts",
      "import": "./dist/esm/utils/env.js",
      "default": "./dist/esm/utils/env.js"
    },
    "./hooks/useGlassProbes": {
      "types": "./dist/hooks/useGlassProbes.d.ts"
    },
    "./services/ai/openai-service": {
      "types": "./dist/services/ai/openai-service.d.ts",
      "import": "./dist/esm/services/ai/openai-service.js",
      "default": "./dist/esm/services/ai/openai-service.js"
    },
    "./services/ai/vision-service": {
      "types": "./dist/services/ai/vision-service.d.ts",
      "import": "./dist/esm/services/ai/vision-service.js",
      "default": "./dist/esm/services/ai/vision-service.js"
    },
    "./services/websocket/collaboration-service": {
      "types": "./dist/services/websocket/collaboration-service.d.ts",
      "import": "./dist/esm/services/websocket/collaboration-service.js",
      "default": "./dist/esm/services/websocket/collaboration-service.js"
    },
    "./registry": {
      "types": "./dist/registry/index.d.ts",
      "import": "./dist/registry/index.mjs",
      "require": "./dist/registry/index.js"
    },
    "./client": {
      "types": "./dist/client/index.d.ts",
      "import": "./dist/client/index.mjs",
      "require": "./dist/client/index.js"
    },
    "./server": {
      "types": "./dist/server/index.d.ts",
      "import": "./dist/server/index.mjs",
      "require": "./dist/server/index.js"
    },
    "./ssr": {
      "types": "./dist/ssr/index.d.ts",
      "import": "./dist/ssr/index.mjs",
      "require": "./dist/ssr/index.js"
    },
    "./three": {
      "types": "./dist/three/index.d.ts",
      "import": "./dist/three/index.mjs",
      "require": "./dist/three/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "workers",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "rollup -c --watch",
    "build:workers": "node scripts/build-workers.js",
    "build:tokens": "node scripts/build-tokens.js",
    "build": "npm run glass:generate-persona-css && node scripts/build-all.js",
    "build:server": "tsc --project tsconfig.server.json",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --fix",
    "lint:check": "eslint src",
    "server:dev": "ts-node server/index.ts",
    "server:websocket": "node server/websocket-server.js",
    "server:api": "node dist/server/index.js",
    "server:all": "concurrently \"npm run server:websocket\" \"npm run server:api\"",
    "server:build-and-start": "npm run build:server && npm run server:all",
    "deploy": "./scripts/deploy.sh",
    "docker:build": "docker-compose build",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "lint:tokens": "node scripts/ci/token-lint.js",
    "lint:styles": "node scripts/ci/style-audit.js",
    "lint:forbidden": "node scripts/ci/forbidden-check.js",
    "lint:ci": "npm run lint:check && npm run lint:tokens && npm run lint:styles && npm run lint:forbidden",
    "test:visual:a11y:ci": "npm run test:visual:a11y",
    "test:regression:ci": "npm run test:all",
    "lint:staged": "lint-staged",
    "prepare": "husky install",
    "test": "jest",
    "test:tokens:exports:cjs": "jest tests/tokens/export.test.ts",
    "test:tokens:exports:esm": "node tests/tokens/export.spec.mjs",
    "test:tokens:exports": "npm run build:tokens && npm run test:tokens:exports:cjs && npm run test:tokens:exports:esm",
    "test:types": "npm run build && tsc --noEmit -p tests/types/tsconfig.json",
    "test:exports:cjs": "jest tests/exports/package-exports.test.ts",
    "test:exports:esm": "node tests/exports/package-exports.spec.mjs",
    "test:exports": "npm run build && npm run test:exports:cjs && npm run test:exports:esm",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:a11y": "jest --testPathPattern=a11y",
    "test:performance": "jest --testPathPattern=performance",
    "test:glass-contrast": "jest --testPathPattern=glass-contrast.spec.ts",
    "test:e2e": "playwright test tests/e2e",
    "test:e2e:ui": "playwright test tests/e2e --ui",
    "test:e2e:headed": "playwright test tests/e2e --headed",
    "test:lighthouse": "lhci autorun",
    "test:visual": "node scripts/visual-test-runner.js",
    "test:visual:headed": "node scripts/visual-test-runner.js --headed",
    "test:visual:update": "node scripts/visual-test-runner.js --update-baselines",
    "test:visual:ci": "playwright test --config=playwright.visual-ci.config.ts",
    "test:visual:matrix": "playwright test --config=playwright.visual-matrix.config.ts",
    "test:visual:components": "node scripts/visual-test-runner.js --grep 'components'",
    "test:visual:responsive": "node scripts/visual-test-runner.js --grep 'responsive'",
    "test:visual:a11y": "node scripts/visual-test-runner.js --grep 'accessibility|a11y'",
    "test:visual:tokens": "node scripts/visual-test-runner.js --grep 'design-system|tokens'",
    "test:all": "npm run test:coverage && npm run test:e2e",
    "test:integration:next": "node scripts/ci/run-next-integration.js",
    "glass:generate-css": "node scripts/generate-glass-css-simple.js",
    "glass:generate-persona-css": "node scripts/generate-persona-css-runner.js",
    "glass:validate-persona-css": "node scripts/generate-persona-css-runner.js --check",
    "glass:validate": "node scripts/verify-glass-pipeline.js",
    "glass:visual-tests": "node scripts/glass-visual-test-generator.js",
    "glass:full-check": "npm run typecheck && npm run lint:check && npm run lint:tokens && npm run lint:styles && npm run glass:validate-persona-css && npm run glass:validate && npm run test:glass-contrast && npm run test:tokens:exports && npm run test:exports && npm run test:types",
    "codemod:tw-to-glass": "node scripts/codemods/tw-to-glass.js",
    "audit:ux": "npm run codemod:tw-to-glass && npm run lint:check && npm run lint:tokens && npm run lint:styles && npm run test:visual:ci",
    "audit:components": "node scripts/audit/universal-glass-audit.js",
    "audit:exports": "node scripts/audit/public-export-audit.js",
    "audit:api": "npm run audit:exports && node scripts/audit/api-surface-audit.js",
    "audit:runtime": "node scripts/audit/runtime-cleanliness-audit.js",
    "codemod:tokens": "node tools/codemods/auraglass-from-raw.mjs",
    "codemod:focus": "node tools/codemods/focusify.mjs",
    "codemod:all": "npm run codemod:tokens && npm run codemod:focus",
    "check:perf": "npm run build && npm run size-check",
    "ci": "npm run glass:full-check && npm run test:coverage",
    "release": "npm run ci && npm publish --provenance --access public",
    "release:dry-run": "npm run ci && npm publish --dry-run --provenance --access public",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "prepublishOnly": "npm run build && npm run verify:pack && npm run test:integration:next -- --skip-build",
    "verify:pack": "node scripts/ci/verify-pack.js",
    "size-check": "bundlesize",
    "analyze": "npm run build && npx bundle-analyzer dist/index.mjs"
  },
  "keywords": [
    "react",
    "react-components",
    "react-ui",
    "nextjs",
    "nextjs-components",
    "glassmorphism",
    "glassmorphism-ui",
    "liquid-glass",
    "apple-liquid-glass",
    "glass-ui",
    "design-system",
    "component-library",
    "ui-components",
    "ui-library",
    "typescript",
    "accessibility",
    "accessible-ui",
    "ssr",
    "react-19",
    "react-18",
    "storybook",
    "design-tokens",
    "tailwindcss",
    "framer-motion",
    "dashboard",
    "data-table",
    "forms",
    "3d-ui",
    "threejs",
    "performance",
    "animation",
    "glass-effects",
    "modern-ui"
  ],
  "author": "AuraOne Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/VeerOneGPT/auraglass.git"
  },
  "bugs": {
    "url": "https://github.com/VeerOneGPT/auraglass/issues"
  },
  "homepage": "https://aura-glass.auraone.com",
