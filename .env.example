# OpenAI Configuration
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4

# Google Cloud Vision Configuration
GOOGLE_CLOUD_PROJECT_ID=your-project-id
GOOGLE_APPLICATION_CREDENTIALS=/path/to/credentials.json
GOOGLE_VISION_API_KEY=your-vision-api-key

# Pinecone Vector Database Configuration
PINECONE_API_KEY=your-pinecone-api-key
PINECONE_ENVIRONMENT=us-east-1
PINECONE_INDEX_NAME=aura-glass-embeddings

# Remove.bg API Configuration
REMOVEBG_API_KEY=your-removebg-api-key

# Redis Configuration
REDIS_URL=redis://localhost:6379

# Authentication Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=1h
REFRESH_TOKEN_EXPIRES_IN=7d
BCRYPT_ROUNDS=10

# Hosted service URLs
WEBSOCKET_SERVER_URL=ws://localhost:3001
COLLABORATION_SERVER_URL=ws://localhost:3001
IMAGE_SERVICE_URL=http://localhost:3002/api/image

# Sentry Error Monitoring
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# Application Environment
NODE_ENV=development
PORT=3000

# Hosted Runtime Ports
API_SERVER_PORT=3002
WS_PORT=3001
NEXT_PUBLIC_API_URL=http://localhost:3002
NEXT_PUBLIC_WS_URL=ws://localhost:3001

# Rate Limiting Configuration
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
AI_RATE_LIMIT_MAX_REQUESTS=50

# Optional Hosted Feature Flags
ENABLE_SMART_FORMS=true
ENABLE_SEMANTIC_SEARCH=false
ENABLE_VISION_API=false
ENABLE_BACKGROUND_REMOVAL=false
ENABLE_COLLABORATION=false

# Local demo-only gates. Keep these false in production.
ENABLE_DEMO_API=false
ENABLE_DEMO_AUTH=false
ALLOW_ANONYMOUS_WS=false

# Cost Optimization Settings
ENABLE_AI_CACHING=true
ENABLE_AI_BATCHING=true
MAX_COST_PER_REQUEST=0.1
USE_CHEAPER_MODELS_THRESHOLD=0.5

# ============================================
# Quick Start Instructions
# ============================================
#
# Production warning:
#    Keep real secrets in a secret manager, not in committed env files.
#    Leave demo-only gates false in NODE_ENV=production.
#
# 1. Copy this file:
#    cp .env.example .env
#
# 2. Get API keys:
#    - OpenAI: https://platform.openai.com/api-keys ($5 free credit for new users)
#    - Pinecone: https://app.pinecone.io/ (Free tier: 100K vectors)
#    - Google Cloud: https://console.cloud.google.com/ ($300 free credit)
#    - Remove.bg: https://www.remove.bg/api (Free tier: 50 images/month)
#
# 3. Install Redis:
#    - macOS: brew install redis && brew services start redis
#    - Ubuntu: sudo apt-get install redis-server && sudo service redis-server start
#    - Docker: docker run -d -p 6379:6379 redis:alpine
#    - Windows: Download from https://redis.io/download
#
# 4. Install dependencies:
#    npm install
#
# 5. Build TypeScript services:
#    npm run build:server
#
# 6. Start servers:
#    npm run server:all
#    (This runs both API server on :3002 and WebSocket server on :3001)
#
# 7. Test the integration:
#    npm run dev
#    Open http://localhost:3000/ai-demo
#
# ============================================
# Pricing Guide (as of 2024)
# ============================================
#
# OpenAI GPT-4 Turbo:
#   - Input: $0.01 per 1K tokens
#   - Output: $0.03 per 1K tokens
#   - Estimate: ~$0.02 per form generation
#
# OpenAI GPT-3.5 Turbo (cheaper alternative):
#   - Input: $0.0005 per 1K tokens
#   - Output: $0.0015 per 1K tokens
#   - Estimate: ~$0.001 per form generation
#
# Pinecone:
#   - Free: 100K vectors, 5M queries/month
#   - Paid: $0.096/hour for pod-based indexes
#
# Google Vision API:
#   - First 1,000 images/month: Free
#   - After: $1.50 per 1,000 images
#
# Remove.bg:
#   - Free: 50 images/month
#   - Paid: Starting at $0.20 per image
#
# Redis:
#   - Self-hosted: Free
#   - Redis Cloud: Free 30MB tier
#
# ============================================
